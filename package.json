{
  "name": "fitforge",
  "version": "1.0.0",
  "description": "fitforge - A powerful fitness app with workout planning and step tracking",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:all": "eas build --platform all",
    "preview": "eas build --platform all --auto-submit false",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:all": "eas submit --platform all",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "fitness",
    "workout",
    "health",
    "mobile",
    "react-native",
    "expo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "expo": "^50.0.0",
    "expo-status-bar": "^1.11.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "@react-native-community/cli": "^12.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0"
  }
}
